# Copy to .env (gitignored) and fill in — never commit real keys.

# Root of your schematic library (the folder the pipeline/app scan).
SCHEMATICS_ROOT=~/Documents/schematics

# Optional: extraction API key for the pipeline (env-only, never hardcoded).
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=

# Note: the macOS app stores its Mouser supplier key in the Keychain, not here.
