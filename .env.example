# Copy this file to .env and fill in your values
# .env is gitignored — never commit real keys

# Mouser Electronics API key (free at https://www.mouser.com/api-hub/)
MOUSER_API_KEY=

# DigiKey API credentials (https://developer.digikey.com/)
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=

# Database path (default: data/workshop.db)
# DATABASE_URL=sqlite:///data/workshop.db
