# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
._*

# ── Swift / Xcode ─────────────────────────────────────────────────────────────
# The .xcodeproj is generated from native/project.yml by XcodeGen — never commit it.
native/PedalWorkshop.xcodeproj/
native/.build/
native/DerivedData/
native/.swiftpm/
native/**/xcuserdata/
native/**/*.xcuserstate

# ── Python (pipeline tooling) ─────────────────────────────────────────────────
.venv/
venv/
**/venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
*.egg-info/

# ── Secrets / local config ────────────────────────────────────────────────────
.env
.env.*
!.env.example
secrets.json

# ── Pipeline: local data & derived assets (NOT redistributed) ─────────────────
# The extraction dataset, the DB, and KiCad output are derived from copyrighted
# schematics and are user-local. Keep them out of the public repo.
pipeline/extractions/
pipeline/extractions_backup/
pipeline/kicad-projects/
pipeline/manifest.json
pipeline/handoff/
pipeline/*.db
pipeline/*.db-shm
pipeline/*.db-wal
pipeline/chrome_profile/
pipeline/_scratch/

# ── App bundle seeds that would leak home paths / copyrighted OCR ─────────────
# These regenerate locally via pipeline/tools/generate_native_index.py +
# analyze_schematics.py; the committed copies are empty placeholders.
# (Tracked as empty [] — see native/Sources/WorkshopCore/Resources/README.md)

# ── Misc scratch ──────────────────────────────────────────────────────────────
*.log
*.tmp

# Internal working docs (not published)
RECODE-PLAN.md
.claude/

# ── Packaged schematic library (copyrighted + ~192MB; populated locally) ──────
native/Sources/WorkshopCore/Resources/Schematics/*
!native/Sources/WorkshopCore/Resources/Schematics/.gitkeep

# ── Ports: Android (Gradle) build artifacts + local config ────────────────────
android/local.properties
android/.gradle/
android/build/
android/app/build/
android/.idea/
android/*.iml
android/.kotlin/

# ── Ports: Python (Flet) ──────────────────────────────────────────────────────
python/.venv/
python/**/__pycache__/
python/.pytest_cache/

# Internal port spec (has absolute reference paths)
android/SPEC.md
